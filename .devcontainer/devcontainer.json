{
  "name": "WWZ Energy Development",
  "build": { "dockerfile": "Dockerfile" },
  "remoteUser": "vscode",
  "forwardPorts": [8123],
  "mounts": [
    "source=${localWorkspaceFolder}/custom_components/wwz_energy,target=/config/custom_components/wwz_energy,type=bind"
  ],
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "fish",
        "terminal.integrated.profiles.linux": {
          "fish": {
            "path": "/usr/bin/fish"
          }
        }
      }
    }
  }
}
